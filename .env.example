# ─── Analyzer LLM (OpenAI-compatible) ──────────────────────────────────────────
# Default: NVIDIA NIM hosting Sarvam-M (OpenAI-compatible, standard Bearer auth,
# generous max_tokens — best fit for this reasoning model).
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=YOUR_NVIDIA_API_KEY      # nvapi-...
LLM_MODEL=sarvamai/sarvam-m
LLM_API_KEY_HEADER=authorization     # standard Authorization: Bearer
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=8192                  # sarvam-m reasons before answering; needs headroom
LLM_TIMEOUT_MS=90000


# ─── Voice ─────────────────────────────────────────────────────────────────────
VOICE_PROVIDER=mock                  # mock | elevenlabs
ELEVENLABS_API_KEY=sk_4aef08e814f49610d883d914d7b81af1e3d79335b5d13ba8
ELEVENLABS_AGENT_ID=agent_0901kv0ja1ysesq909hnm4hskh5w
ELEVENLABS_AGENT_PHONE_NUMBER_ID=
ON_CALL_PHONE_NUMBER=
PUBLIC_WEBHOOK_URL=

# ─── Watcher thresholds (the cheap gate) ───────────────────────────────────────
ERROR_RATE_THRESHOLD=0.2
CONSECUTIVE_SAMPLES=3
P95_LATENCY_MS_THRESHOLD=1500
MEMORY_MB_THRESHOLD=400
WAKE_ON_ANY_ERROR_LINE=false         # looser gate => more AI involvement
DECISION_TIMEOUT_MS=300000           # awaiting_decision -> escalated if no answer (5 min for live calls)
VERIFY_WINDOW_MS=10000               # how long to re-check health after a fix

# ─── Monitored target: the REAL server (services/real-test-server) ─────────────
# The operator starts/stops/heals this on demand from the dashboard; it is NOT in
# docker-compose. Build the two images first:  ./scripts/build-real-images.sh
TARGET_CONTAINER=siren-real-server
TARGET_URL=http://siren-real-server:5000
TARGET_GOOD_IMAGE=siren-real-server:v1   # healthy build
TARGET_BAD_IMAGE=siren-real-server:v2    # broken build (bad release)
TARGET_HEALTH_PATH=/health
TARGET_PORT=5000
TARGET_HOST_PORT=5050                     # host port the target publishes
TARGET_MONGODB_URI=                       # optional; health is decoupled from Mongo
TARGET_JWT_SECRET=siren-demo-secret

# ─── Service wiring (used by docker-compose) ───────────────────────────────────
OPERATOR_PORT=4000
DASHBOARD_PORT=5173
